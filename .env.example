# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # NEVER expose client-side
SUPABASE_PROJECT_ID=your-project-ref

# ── Stripe ───────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...          # Use sk_test_... for development
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe webhook dashboard

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app  # No trailing slash

# ── Optional: Email (e.g. Resend) ───────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@digitalheroes.co.in

# ── Notes ────────────────────────────────────────────────────
# After creating Stripe products, update platform_settings in DB:
#   stripe_monthly_price -> price_xxxxx (monthly Price ID)
#   stripe_yearly_price  -> price_xxxxx (yearly Price ID)
#
# Stripe webhook events to enable:
#   - checkout.session.completed
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_failed
